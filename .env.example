INPUT_MD_CLIENT_ID=personal-client-...
INPUT_MD_CLIENT_SECRET=your-client-secret
INPUT_MD_REFRESH_TOKEN=your-refresh-token
# You can use MD_CLIENT_ID, MD_CLIENT_SECRET, and MD_REFRESH_TOKEN instead.
INPUT_REPO_FILENAME=README.md
INPUT_DISPLAY_LIMIT=10
INPUT_SORT_BY=latestUploadedChapter
INPUT_SORT_ORDER=desc
INPUT_TITLE_LANGUAGE=en
INPUT_FALLBACK_TITLE_LANGUAGE=ja-ro
INPUT_CONTENT_RATINGS=safe,suggestive,erotica
# Default avoids MangaDex's anti-hotlink placeholder from mangadex.org/covers.
INPUT_COVER_URL_FORMAT=https://uploads.mangadex.org/covers/${mangaId}/${coverFileName}.256.jpg
# Optional cover proxy. The default example uses the Hugging Face image proxy.
# For a general CORS proxy, use https://cor.brtree.dpdns.org/${url}
INPUT_COVER_PROXY_URL=https://apsiknb-image.hf.space${path}
# Optional metadata formatter. Leave unset for the built-in default: status / ch. lastChapter / year.
# Use an empty value to hide metadata for that scope.
# INPUT_METADATA_FORMAT=${status} / ${lastRead}/${lastChapter} / ${year}
# INPUT_METADATA_FORMAT_READING=${status} / ${progress} / ${year}
# INPUT_METADATA_FORMAT_PLAN_TO_READ=
# Optional empty block message. Use an empty value to hide it for that scope.
# INPUT_EMPTY_MESSAGE=No MangaDex entries found for ${libraryStatus}.
# INPUT_EMPTY_MESSAGE_RE_READING=Nothing in ${libraryStatus}.
TARGET_REPOSITORY_DIR=.
MANGADEX_DOH=true
MANGADEX_DNS=1.1.1.1
MANGADEX_DOH_TIMEOUT_MS=5000
MANGADEX_HTTP_TIMEOUT_MS=30000
MANGADEX_DNS_DEBUG=false
MANGADEX_UPDATE_ENV_REFRESH_TOKEN=true
